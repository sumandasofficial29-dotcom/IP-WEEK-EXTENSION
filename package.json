{
  "name": "promptcraft",
  "displayName": "PromptCraft",
  "description": "Smart prompt generator that helps you get accurate Copilot solutions in fewer tries.",
  "version": "1.0.0",
  "private": true,
  "author": "Your Name",
  "license": "MIT",
  "publisher": "Amadeus",
  "repository": {
    "type": "git",
    "url": "https://github.com/Amadeus/repo-intelligence-prompt-engine.git"
  },
  "engines": {
    "node": ">=18.0.0",
    "vscode": "^1.85.0"
  },
  "extensionKind": [
    "workspace"
  ],
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "*"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "repoPrompt",
          "title": "Repo Prompt",
          "icon": "media/icon.svg"
        }
      ]
    },
    "views": {
      "repoPrompt": [
        {
          "type": "webview",
          "id": "repoPrompt.sidebar",
          "name": "Prompt Builder"
        }
      ]
    },
    "commands": [
      {
        "command": "repoPrompt.generate",
        "title": "PromptCraft: Generate Smart Prompt"
      },
      {
        "command": "repoPrompt.cacheStats",
        "title": "PromptCraft: Show Last Scan Time"
      },
      {
        "command": "repoPrompt.clearCache",
        "title": "PromptCraft: Clear Cache"
      }
    ]
  },
  "types": "dist/extension.d.ts",
  "scripts": {
    "build": "tsc",
    "watch": "tsc -w",
    "clean": "rimraf dist",
    "start": "node dist/extension.js",
    "dev": "ts-node src/extension.ts",
    "lint": "eslint . --ext .ts",
    "vscode:prepublish": "npm run build"
  },
  "dependencies": {
    "glob": "^10.3.10",
    "typescript": "^5.4.5"
  },
  "devDependencies": {
    "@types/node": "^20.11.30",
    "@types/vscode": "^1.85.0",
    "ts-node": "^10.9.2",
    "rimraf": "^5.0.5",
    "eslint": "^8.57.0",
    "@typescript-eslint/parser": "^7.2.0",
    "@typescript-eslint/eslint-plugin": "^7.2.0"
  }
}